# Gradle build outputs
.gradle/
build/
**/build/

# Explicitly keep wrapper scripts (required for CI/CD)
!gradlew
!gradlew.bat
!gradle/wrapper/gradle-wrapper.jar
!gradle/wrapper/gradle-wrapper.properties
!gradle/libs.versions.toml

# IntelliJ / Android Studio
*.iml
.idea/
*.iws
*.ipr
local.properties
out/

# Android signed APKs / keystores (keep these secret)
/app/release/
*.apk
*.aab
*.jks
*.keystore

# Kotlin compiled
*.class

# macOS
.DS_Store
**/.DS_Store

# Windows
Thumbs.db
ehthumbs.db

# Misc
*.bak
*.tmp
*.swp
